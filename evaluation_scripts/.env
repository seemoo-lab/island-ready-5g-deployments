# =========================
# Docker build config
# =========================
CPU_QUOTA=-1

# Images
GEN_IMAGE_NAME=pobtog-gen
EVAL_IMAGE_NAME=pobtog-eval
PLOT_IMAGE_NAME=pobtog-plot

# Containers
GEN_CONTAINER_NAME=pobtog-gen
EVAL_CONTAINER_NAME=pobtog-eval
PLOT_CONTAINER_NAME=pobtog-plot

# =========================
# Paths
# =========================
DATA_DIR=/path/to/this/repo/evaluation_scripts/pobtog/data
TOPOLOGIES_DIR=/path/to/this/repo/evaluation_scripts/generation/results
EVAL_OUTPUT_DIR=/path/to/this/repo/evaluation_scripts/evaluation/results
PLOT_OUTPUT_DIR=/path/to/this/repo/evaluation_scripts/plotting/results
POBTOG_DATA_DIR=/path/to/this/repo/evaluation_scripts/plotting/data

# =========================
# Parameters
# =========================
GEN_REPLICA_FACTOR_ARRAY=5,10,15,20,25,30,35,40,45,50
GEN_TOPO_ARRAY=star,ring
EVAL_REPLICA_FACTOR_ARRAY=5,10,15,20,25,30,35,40,45,50

EVAL_A_TOPO_ARRAY=star
EVAL_A_REPLICA_AVAIL=0.99999
EVAL_A_LINK_AVAIL=0.999,0.9999,0.99999,0.999999

EVAL_B_TOPO_ARRAY=star
EVAL_B_REPLICA_AVAIL=0.5,0.6,0.7,0.8,0.9
EVAL_B_LINK_AVAIL=0.99999

EVAL_C_TOPO_ARRAY=star,ring
EVAL_C_REPLICA_AVAIL=0.99999
EVAL_C_LINK_AVAIL=0.99999
